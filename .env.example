# EVE SSO OAuth client settings
EVE_SSO_CLIENT_ID=your-eve-sso-client-id
EVE_SSO_CLIENT_SECRET=your-eve-sso-client-secret
EVE_SSO_CALLBACK_URL=http://localhost:3000/api/auth/callback

# Session encryption/signing secret (set a long random value)
SESSION_SECRET=replace-with-a-long-random-string

# Optional bootstrap admin character name for first login before allowlist is configured
BOOTSTRAP_ADMIN_CHARACTER_NAME=

# Data storage directory (inside container defaults to /data)
DATA_DIR=./data

# SeAT API integration
SEAT_BASE_URL=https://seat.example.com
SEAT_API_KEY=replace-with-seat-api-key

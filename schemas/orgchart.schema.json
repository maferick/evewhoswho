{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evewhoswho.local/schemas/orgchart.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "nodes", "edges", "permissions"],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "title", "updatedAt"],
      "properties": {
        "version": { "type": "integer", "minimum": 1 },
        "title": { "type": "string", "minLength": 1 },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "nodes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["roles", "directorates", "teams", "corporations"],
      "properties": {
        "roles": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "name", "teamId"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "name": { "type": "string", "minLength": 1 },
              "teamId": { "type": "string", "minLength": 1 }
            }
          }
        },
        "directorates": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "name", "corporationId"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "name": { "type": "string", "minLength": 1 },
              "corporationId": { "type": "string", "minLength": 1 }
            }
          }
        },
        "teams": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "name", "directorateId"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "name": { "type": "string", "minLength": 1 },
              "directorateId": { "type": "string", "minLength": 1 }
            }
          }
        },
        "corporations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "name"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "name": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "sourceId", "targetId"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "sourceId": { "type": "string", "minLength": 1 },
          "targetId": { "type": "string", "minLength": 1 }
        }
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adminCharacterIds"],
      "properties": {
        "adminCharacterIds": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1 },
          "uniqueItems": true
        }
      }
    }
  }
}
